    given-names: "Mathis"
    affiliation: "Institut de la Vision, Paris"
repository-code: "https://github.com/mathisbouvet/spatial-cluster-compare"
url: "https://pypi.org/project/spatial-cluster-compare/"
version: 0.1.2
date-released: "2026-06-19"
license: MIT
keywords:
  - bioinformatics
  - clustering
  - single-cell
  - spatial-proteomics
